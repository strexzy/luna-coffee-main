# Пример переменных окружения. Скопируй в .env.local при необходимости.
# Пока бэкенда нет, значения по умолчанию зашиты в shared/config/env.ts —
# проект работает и без .env-файла.

# Мок-режим (true по умолчанию). false — ходить в реальный API.
NEXT_PUBLIC_USE_MOCKS=true

# Базовый URL REST API (появится вместе с Node.js-бэкендом).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Адрес WebSocket-сервера (фаза 6).
NEXT_PUBLIC_WS_URL=ws://localhost:4000
